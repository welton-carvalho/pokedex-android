flowchart TD
    subgraph list["feature:pokemon-list - alterado"]
        listScreen["PokemonListScreen<br/>botao Comparar + contador n/2"]
        listViewModel[PokemonListViewModel]
        listReducer["PokemonListReducer<br/>+ isCompareMode, selectedIds"]
        listScreen -->|"ToggleCompareMode / ToggleSelection"| listViewModel
        listViewModel --> listReducer
    end

    listViewModel -->|"Event.NavigateToCompare(a,b)"| compareKey
    compareKey["PokemonCompareKey(a,b)<br/>core:route:keys"] --> navDisplay
    navDisplay["AppNavDisplay<br/>core:route:navigation"] -->|pokemonCompareEntry| compareScreen

    subgraph compare["feature:pokemon-compare - novo"]
        compareScreen[CompareScreen] --> compareViewModel[CompareViewModel]
        compareViewModel -->|"async x2"| useCase[GetPokemonDetailUseCase]
        compareViewModel --> compareReducer[CompareReducer]
        compareViewModel --> compareMapper["toCompareUiModel<br/>+ buildStatComparison"]
    end

    useCase --> repository[("PokemonRepository<br/>inalterado")]

    classDef altered fill:#f59e0b,stroke:#d97706,color:#ffffff;
    classDef created fill:#4f46e5,stroke:#3730a3,color:#ffffff;
    classDef route fill:#64748b,stroke:#475569,color:#ffffff;
    classDef data fill:#10b981,stroke:#059669,color:#ffffff;

